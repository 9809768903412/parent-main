generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ProductStatus {
  AVAILABLE
  LOW_STOCK
  OUT_OF_STOCK
  DISCONTINUED
}

enum MaterialRequestStatus {
  PENDING
  APPROVED
  REJECTED
  FULFILLED
}

enum MaterialUrgency {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum ClientOrderStatus {
  PENDING
  APPROVED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  VERIFIED
  PAID
  FAILED
}

enum DeliveryStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  RETURN_PENDING
  RETURN_REJECTED
  RETURNED
  DELAYED
}

enum ProjectStatus {
  PENDING
  REJECTED
  ACTIVE
  ON_HOLD
  COMPLETED
}

enum SupplierOrderStatus {
  DRAFT
  PENDING
  APPROVED
  ORDERED
  RECEIVED
  PAID
  CANCELLED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  CONFIRM
  LOGIN
  LOGIN_FAILED
  VIEW
  NOTIFY
  VERIFY
  TEST
}

enum NotificationType {
  LOW_STOCK
  ORDER_APPROVAL
  DELIVERY_UPDATE
  PAYMENT_VERIFIED
  REQUEST_APPROVAL
  QUOTE_RESPONSE
  AI_ALERT
  PROJECT_UPDATE
}

enum QuoteStatus {
  PENDING
  RESPONDED
  ACCEPTED
  DECLINED
}

enum ClientVisibilityScope {
  COMPANY
  USER
}

enum StockTransactionType {
  PURCHASE
  ISSUE
  RETURN
  ADJUSTMENT
}

model Role {
  roleId   Int    @id @default(autoincrement()) @map("role_id")
  roleName String @unique @map("role_name") @db.VarChar(50)

  users     User[]
  userRoles UserRole[]

  @@map("roles")
}

model User {
  userId                Int        @id @default(autoincrement()) @map("user_id")
  fullName              String     @map("full_name") @db.VarChar(150)
  email                 String     @unique @db.VarChar(150)
  passwordHash          String     @map("password_hash")
  roleId                Int?       @map("role_id")
  status                UserStatus @default(ACTIVE)
  emailVerified         Boolean    @default(true) @map("email_verified")
  verificationCodeHash  String?    @map("verification_code_hash") @db.Text
  verificationExpiresAt DateTime?  @map("verification_expires_at")
  resetCodeHash         String?    @map("reset_code_hash") @db.Text
  resetExpiresAt        DateTime?  @map("reset_expires_at")
  phone                 String?    @db.VarChar(30)
  avatarUrl             String?    @map("avatar_url") @db.Text
  proofDocUrl           String?    @map("proof_doc_url") @db.Text
  otpCodeHash           String?    @map("otp_code_hash") @db.Text
  otpExpiresAt          DateTime?  @map("otp_expires_at")
  notificationPrefs     Json?      @map("notification_prefs")
  createdAt             DateTime   @default(now()) @map("created_at")
  deletedAt             DateTime?  @map("deleted_at")

  role                     Role?              @relation(fields: [roleId], references: [roleId])
  userRoles                UserRole[]
  materialRequests         MaterialRequest[]
  approvedRequests         MaterialRequest[]  @relation("MaterialRequestApprover")
  auditLogs                AuditLog[]
  stockTransactions        StockTransaction[]
  notifications            Notification[]
  productWatches           ProductWatch[]     @relation("UserProductWatches")
  assignedProjects         Project[]          @relation("ProjectAssignedPm")
  assignedClientOrders     ClientOrder[]      @relation("ClientOrderAssignedSalesAgent")
  assignedMaterialRequests MaterialRequest[]  @relation("MaterialRequestAssignedPm")
  assignedDeliveries       Delivery[]         @relation("DeliveryAssignedDeliveryGuy")

  @@index([roleId])
  @@map("users")
}

model UserRole {
  userId Int @map("user_id")
  roleId Int @map("role_id")

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [roleId], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model PendingRegistration {
  pendingId             Int       @id @default(autoincrement()) @map("pending_id")
  fullName              String    @map("full_name") @db.VarChar(150)
  email                 String    @unique @db.VarChar(150)
  passwordHash          String    @map("password_hash")
  roleName              String    @map("role_name") @db.VarChar(50)
  companyName           String?   @map("company_name") @db.VarChar(150)
  proofDocUrl           String?   @map("proof_doc_url") @db.Text
  verificationCodeHash  String?   @map("verification_code_hash") @db.Text
  verificationExpiresAt DateTime? @map("verification_expires_at")
  createdAt             DateTime  @default(now()) @map("created_at")

  @@map("pending_registrations")
}

model CompanySetting {
  companyId Int      @id @default(autoincrement()) @map("company_id")
  name      String   @db.VarChar(150)
  address   String   @db.Text
  tin       String   @db.VarChar(50)
  phone     String   @db.VarChar(50)
  email     String   @db.VarChar(150)
  website   String   @db.VarChar(150)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("company_settings")
}

model ProductCategory {
  categoryId   Int       @id @default(autoincrement()) @map("category_id")
  categoryName String    @unique @map("category_name") @db.VarChar(100)
  deletedAt    DateTime? @map("deleted_at")

  products Product[]

  @@map("product_categories")
}

model Product {
  productId         Int           @id @default(autoincrement()) @map("product_id")
  itemName          String        @map("item_name") @db.VarChar(150)
  unit              String?       @db.VarChar(50)
  unitPrice         Decimal       @map("unit_price") @db.Decimal(12, 2)
  categoryId        Int?          @map("category_id")
  status            ProductStatus @default(AVAILABLE)
  qtyOnHand         Int           @default(0) @map("qty_on_hand")
  lowStockThreshold Int           @default(20) @map("low_stock_threshold")
  shelfLifeDays     Int           @default(180) @map("shelf_life_days")
  createdAt         DateTime      @default(now()) @map("created_at")
  deletedAt         DateTime?     @map("deleted_at")

  category             ProductCategory?      @relation(fields: [categoryId], references: [categoryId])
  supplierOrderItems   SupplierOrderItem[]
  materialRequestItems MaterialRequestItem[]
  clientOrderItems     ClientOrderItem[]
  stockTransactions    StockTransaction[]
  watches              ProductWatch[]

  @@index([categoryId])
  @@map("products")
}

model ProductWatch {
  watchId   Int      @id @default(autoincrement()) @map("watch_id")
  productId Int?     @map("product_id")
  userId    Int?     @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  product Product? @relation(fields: [productId], references: [productId], onDelete: Cascade)
  user    User?    @relation("UserProductWatches", fields: [userId], references: [userId], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
  @@map("product_watches")
}

model Client {
  clientId        Int                   @id @default(autoincrement()) @map("client_id")
  clientName      String                @map("client_name") @db.VarChar(150)
  address         String?               @db.Text
  email           String?               @db.VarChar(150)
  contactPerson   String?               @map("contact_person") @db.VarChar(150)
  phone           String?               @db.VarChar(50)
  tin             String?               @db.VarChar(50)
  visibilityScope ClientVisibilityScope @default(COMPANY) @map("visibility_scope")
  deletedAt       DateTime?             @map("deleted_at")

  projects      Project[]
  clientOrders  ClientOrder[]
  quoteRequests QuoteRequest[]

  @@map("clients")
}

model Project {
  projectId       Int           @id @default(autoincrement()) @map("project_id")
  projectName     String        @map("project_name") @db.VarChar(150)
  clientId        Int?          @map("client_id")
  assignedPmId    Int?          @map("assigned_pm_id")
  location        String?       @db.Text
  status          ProjectStatus @default(ACTIVE)
  startDate       DateTime?     @map("start_date") @db.Date
  totalValue      Decimal       @default(0) @map("total_value") @db.Decimal(12, 2)
  rejectionReason String?       @map("rejection_reason") @db.Text
  deletedAt       DateTime?     @map("deleted_at")

  client           Client?           @relation(fields: [clientId], references: [clientId])
  assignedPm       User?             @relation("ProjectAssignedPm", fields: [assignedPmId], references: [userId])
  supplierOrders   SupplierOrder[]
  materialRequests MaterialRequest[]
  clientOrders     ClientOrder[]
  quoteRequests    QuoteRequest[]

  @@index([clientId])
  @@index([assignedPmId])
  @@map("projects")
}

model Supplier {
  supplierId   Int       @id @default(autoincrement()) @map("supplier_id")
  supplierName String    @map("supplier_name") @db.VarChar(150)
  country      String?   @db.VarChar(100)
  email        String?   @db.VarChar(150)
  address      String?   @db.Text
  phone        String?   @db.VarChar(50)
  tin          String?   @db.VarChar(50)
  deletedAt    DateTime? @map("deleted_at")

  supplierOrders SupplierOrder[]

  @@map("suppliers")
}

model SupplierOrder {
  orderId      Int                 @id @default(autoincrement()) @map("order_id")
  supplierId   Int?                @map("supplier_id")
  projectId    Int?                @map("project_id")
  orderDate    DateTime            @default(now()) @map("order_date") @db.Date
  status       SupplierOrderStatus @default(PENDING)
  terms        String?             @db.VarChar(100)
  remarks      String?             @db.Text
  subtotal     Decimal?            @db.Decimal(12, 2)
  vat          Decimal?            @db.Decimal(12, 2)
  total        Decimal?            @db.Decimal(12, 2)
  approvedBy   String?             @map("approved_by")
  approvedById Int?                @map("approved_by_id")
  deletedAt    DateTime?           @map("deleted_at")

  supplier Supplier?           @relation(fields: [supplierId], references: [supplierId])
  project  Project?            @relation(fields: [projectId], references: [projectId])
  items    SupplierOrderItem[]

  @@index([supplierId])
  @@index([projectId])
  @@index([approvedById])
  @@map("orders")
}

model SupplierOrderItem {
  orderItemId Int     @id @default(autoincrement()) @map("order_item_id")
  orderId     Int?    @map("order_id")
  productId   Int?    @map("product_id")
  quantity    Int
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)

  order   SupplierOrder? @relation(fields: [orderId], references: [orderId], onDelete: Cascade)
  product Product?       @relation(fields: [productId], references: [productId])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model MaterialRequest {
  requestId                Int                   @id @default(autoincrement()) @map("request_id")
  requestNumber            String                @unique @map("request_number") @db.VarChar(50)
  projectId                Int?                  @map("project_id")
  requestedBy              Int?                  @map("requested_by")
  approvedBy               Int?                  @map("approved_by")
  assignedProjectManagerId Int?                  @map("assigned_project_manager_id")
  requestDate              DateTime              @default(now()) @map("request_date") @db.Date
  status                   MaterialRequestStatus @default(PENDING)
  urgency                  MaterialUrgency?
  estCost                  Decimal?              @map("est_cost") @db.Decimal(12, 2)
  purpose                  String?               @db.Text
  remarks                  String?               @db.Text
  approvedAt               DateTime?             @map("approved_at")
  createdAt                DateTime              @default(now()) @map("created_at")
  deletedAt                DateTime?             @map("deleted_at")

  project                Project?              @relation(fields: [projectId], references: [projectId])
  requester              User?                 @relation(fields: [requestedBy], references: [userId])
  approver               User?                 @relation("MaterialRequestApprover", fields: [approvedBy], references: [userId])
  assignedProjectManager User?                 @relation("MaterialRequestAssignedPm", fields: [assignedProjectManagerId], references: [userId])
  items                  MaterialRequestItem[]

  @@index([projectId])
  @@index([requestedBy])
  @@index([approvedBy])
  @@index([assignedProjectManagerId])
  @@map("material_requests")
}

model MaterialRequestItem {
  itemId    Int     @id @default(autoincrement()) @map("item_id")
  requestId Int?    @map("request_id")
  productId Int?    @map("product_id")
  quantity  Int
  notes     String? @map("notes") @db.Text

  request MaterialRequest? @relation(fields: [requestId], references: [requestId], onDelete: Cascade)
  product Product?         @relation(fields: [productId], references: [productId])

  @@index([requestId])
  @@index([productId])
  @@map("material_request_items")
}

model ClientOrder {
  clientOrderId        Int               @id @default(autoincrement()) @map("client_order_id")
  orderNumber          String            @unique @map("order_number") @db.VarChar(50)
  projectId            Int?              @map("project_id")
  clientId             Int?              @map("client_id")
  assignedSalesAgentId Int?              @map("assigned_sales_agent_id")
  subtotal             Decimal?          @db.Decimal(12, 2)
  vat                  Decimal?          @db.Decimal(12, 2)
  total                Decimal?          @db.Decimal(12, 2)
  status               ClientOrderStatus @default(PENDING)
  paymentStatus        PaymentStatus     @default(PENDING) @map("payment_status")
  paymentProofUrl      String?           @map("payment_proof_url") @db.Text
  chequeVerification   String?           @map("cheque_verification") @db.VarChar(20)
  orderDate            DateTime          @default(now()) @map("order_date") @db.Date
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")
  createdBy            Int?              @map("created_by")
  specialInstructions  String?           @map("special_instructions") @db.Text
  cancelReason         String?           @map("cancel_reason") @db.Text
  deletedAt            DateTime?         @map("deleted_at")

  project            Project?          @relation(fields: [projectId], references: [projectId])
  client             Client?           @relation(fields: [clientId], references: [clientId])
  assignedSalesAgent User?             @relation("ClientOrderAssignedSalesAgent", fields: [assignedSalesAgentId], references: [userId])
  items              ClientOrderItem[]
  deliveries         Delivery[]

  @@index([projectId])
  @@index([clientId])
  @@index([assignedSalesAgentId])
  @@map("client_orders")
}

model ClientOrderItem {
  itemId        Int      @id @default(autoincrement()) @map("item_id")
  clientOrderId Int?     @map("client_order_id")
  productId     Int?     @map("product_id")
  quantity      Int
  unitPrice     Decimal? @map("unit_price") @db.Decimal(12, 2)

  clientOrder ClientOrder? @relation(fields: [clientOrderId], references: [clientOrderId], onDelete: Cascade)
  product     Product?     @relation(fields: [productId], references: [productId])

  @@index([clientOrderId])
  @@index([productId])
  @@map("client_order_items")
}

model Delivery {
  deliveryId            Int            @id @default(autoincrement()) @map("delivery_id")
  drNumber              String         @unique @map("dr_number") @db.VarChar(50)
  clientOrderId         Int?           @map("client_order_id")
  assignedDeliveryGuyId Int?           @map("assigned_delivery_guy_id")
  status                DeliveryStatus @default(PENDING)
  eta                   DateTime?      @db.Date
  itemsCount            Int?           @map("items_count")
  createdAt             DateTime       @default(now()) @map("created_at")
  receivedAt            DateTime?      @map("received_at")
  receivedBy            String?        @map("received_by")
  proofOfDeliveryUrl    String?        @map("proof_of_delivery_url") @db.Text
  notes                 String?        @db.Text
  returnRejectionReason String?        @map("return_rejection_reason") @db.Text
  deletedAt             DateTime?      @map("deleted_at")

  clientOrder         ClientOrder? @relation(fields: [clientOrderId], references: [clientOrderId])
  assignedDeliveryGuy User?        @relation("DeliveryAssignedDeliveryGuy", fields: [assignedDeliveryGuyId], references: [userId])

  @@index([clientOrderId])
  @@index([assignedDeliveryGuyId])
  @@map("deliveries")
}

model AuditLog {
  logId     Int         @id @default(autoincrement()) @map("log_id")
  userId    Int?        @map("user_id")
  timestamp DateTime    @default(now())
  action    AuditAction
  target    String      @db.VarChar(100)
  details   String?     @db.Text

  user User? @relation(fields: [userId], references: [userId])

  @@index([userId])
  @@index([timestamp])
  @@map("audit_logs")
}

model Notification {
  notificationId Int              @id @default(autoincrement()) @map("notification_id")
  userId         Int?             @map("user_id")
  type           NotificationType
  title          String           @db.VarChar(150)
  message        String           @db.Text
  link           String?          @db.VarChar(200)
  read           Boolean          @default(false)
  createdAt      DateTime         @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [userId])

  @@index([userId])
  @@index([createdAt])
  @@map("notifications")
}

model QuoteRequest {
  quoteRequestId     Int         @id @default(autoincrement()) @map("quote_request_id")
  clientId           Int?        @map("client_id")
  projectId          Int?        @map("project_id")
  status             QuoteStatus @default(PENDING)
  createdAt          DateTime    @default(now()) @map("created_at")
  respondedAt        DateTime?   @map("responded_at")
  quotedAmount       Decimal?    @map("quoted_amount") @db.Decimal(12, 2)
  customRequirements String?     @map("custom_requirements") @db.Text
  deletedAt          DateTime?   @map("deleted_at")

  client  Client?            @relation(fields: [clientId], references: [clientId])
  project Project?           @relation(fields: [projectId], references: [projectId])
  items   QuoteRequestItem[]

  @@index([clientId])
  @@index([projectId])
  @@map("quote_requests")
}

model QuoteRequestItem {
  quoteRequestItemId Int     @id @default(autoincrement()) @map("quote_request_item_id")
  quoteRequestId     Int?    @map("quote_request_id")
  itemName           String  @map("item_name") @db.VarChar(150)
  quantity           Int
  notes              String? @db.Text

  quoteRequest QuoteRequest? @relation(fields: [quoteRequestId], references: [quoteRequestId], onDelete: Cascade)

  @@index([quoteRequestId])
  @@map("quote_request_items")
}

model StockTransaction {
  transactionId Int                  @id @default(autoincrement()) @map("transaction_id")
  productId     Int?                 @map("product_id")
  date          DateTime             @default(now())
  type          StockTransactionType
  qtyChange     Int                  @map("qty_change")
  newBalance    Int                  @map("new_balance")
  userId        Int?                 @map("user_id")
  notes         String?              @db.Text

  product Product? @relation(fields: [productId], references: [productId])
  user    User?    @relation(fields: [userId], references: [userId])

  @@index([productId])
  @@index([userId])
  @@map("stock_transactions")
}
